# ============================================================
# POCO Garage Doors — Hostinger production config
# Place in: public_html/.htaccess
# ============================================================

AddDefaultCharset UTF-8
Options -Indexes
ServerSignature Off

# ------------------------------------------------------------
# 1. FORCE HTTPS + canonicalize to www
#    (canonical URL = https://www.portcoquitlamgaragedoors.ca/)
# ------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http -> https
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # non-www -> www
  RewriteCond %{HTTP_HOST} ^portcoquitlamgaragedoors\.ca$ [NC]
  RewriteRule ^(.*)$ https://www.portcoquitlamgaragedoors.ca/$1 [L,R=301]

  # 301 legacy area URLs (renamed for SEO keyword targeting)
  RedirectMatch 301 ^/coquitlam/?$ /garage-door-repair-coquitlam/
  RedirectMatch 301 ^/port-coquitlam/?$ /garage-door-repair-port-coquitlam/
  RedirectMatch 301 ^/port-moody/?$ /garage-door-repair-port-moody/
</IfModule>

# ------------------------------------------------------------
# 2. COMPRESSION (gzip + brotli where available)
# ------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE application/rss+xml application/atom+xml
  AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
  AddOutputFilterByType DEFLATE font/ttf font/otf application/font-woff application/font-woff2
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ------------------------------------------------------------
# 3. BROWSER CACHING
# ------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                        "access plus 1 month"
  # HTML — short cache so updates ship fast
  ExpiresByType text/html               "access plus 1 hour"
  # Assets — long cache (filenames change rarely)
  ExpiresByType text/css                "access plus 1 month"
  ExpiresByType application/javascript  "access plus 1 month"
  ExpiresByType application/json        "access plus 1 day"
  # Images
  ExpiresByType image/jpeg              "access plus 6 months"
  ExpiresByType image/png               "access plus 6 months"
  ExpiresByType image/webp              "access plus 6 months"
  ExpiresByType image/svg+xml           "access plus 6 months"
  ExpiresByType image/x-icon            "access plus 1 year"
  # Fonts
  ExpiresByType font/woff               "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  ExpiresByType font/ttf                "access plus 1 year"
  # Manifest & robots
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType text/xml                "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Cache-Control for images & fonts — immutable, can be cached aggressively
  <FilesMatch "\.(jpe?g|png|gif|svg|webp|ico|woff2?|ttf|otf)$">
    Header set Cache-Control "public, max-age=15552000, immutable"
  </FilesMatch>
  # Cache-Control for CSS/JS
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # No caching for HTML so site updates propagate quickly
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ------------------------------------------------------------
# 4. SECURITY HEADERS
# ------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options          "nosniff"
  Header set X-Frame-Options                 "SAMEORIGIN"
  Header set Referrer-Policy                 "strict-origin-when-cross-origin"
  Header set X-XSS-Protection                "1; mode=block"
  Header set Permissions-Policy              "geolocation=(), microphone=(), camera=()"
  # HSTS — turn on once you've confirmed SSL is solid
  # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Remove ETag (we use Last-Modified + Expires; ETag adds noise)
  Header unset ETag
</IfModule>
FileETag None

# ------------------------------------------------------------
# 5. MIME TYPES (font + image safety net)
# ------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/webp                 .webp
  AddType image/svg+xml              .svg .svgz
  AddType application/font-woff      .woff
  AddType application/font-woff2     .woff2
  AddType application/manifest+json  .webmanifest
</IfModule>

# ------------------------------------------------------------
# 6. PRETTY URLS
# ------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Strip /index.html from any URL so canonical = directory URL
  # e.g. /spring-repair/index.html -> /spring-repair/
  RewriteCond %{THE_REQUEST} \s/+(.*?)index\.html[\s?] [NC]
  RewriteRule ^ /%1 [L,R=301]

  # Add trailing slash to directory URLs
  # e.g. /spring-repair -> /spring-repair/
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # 301 legacy hash anchors from the old single-page app to their new URLs.
  # These only work for clients that follow Refresh meta (not browsers that
  # never send the hash to the server), but they help when the hash is
  # accidentally exposed in copy/paste/scraped links. The bulk of legacy
  # hash handling is done client-side in scripts.js on the home page.

  # If a .html version exists at the requested path, serve it without the extension
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ------------------------------------------------------------
# 7. CUSTOM ERROR PAGES
# ------------------------------------------------------------
ErrorDocument 404 /index.html
